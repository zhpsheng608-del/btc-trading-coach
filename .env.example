# ============================================
# BTC 交易教练 - 环境变量配置
# ============================================
# 将此文件复制为 .env 并填入实际值
# cp .env.example .env
# ============================================

# === OpenAI API Key (Codex CLI 必需) ===
# 用于 Codex CLI 调用 AI 模型进行分析
OPENAI_API_KEY=sk-your-openai-api-key-here

# === 钉钉机器人 Webhook ===
# 钉钉群聊中添加自定义机器人后获取的 Webhook URL
# 格式: https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token-here

# === 钉钉签名密钥 (可选，推荐) ===
# 如果钉钉机器人启用了"加签"安全设置，填入此处
# 未启用则留空
DINGTALK_SECRET=your-dingtalk-secret-here

# === Codex CLI 路径 (可选) ===
# 默认为 PATH 中的 "codex"，通常由 npm install -g 安装
# CODEX_BIN=/usr/local/bin/codex

# === 模型选择 (可选) ===
# 默认为 o3-mini
# MODEL=o3-mini
